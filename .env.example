# Kraken API Credentials
# Used ONLY for fetching price data - no orders are ever placed
# Get your API key at: https://www.kraken.com/u/security/api
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_PRIVATE_KEY=your_kraken_private_key_here

# Trading Pair (Kraken format)
TRADING_PAIR=XXBTZUSD
PAIR_DISPLAY=BTC/USD

# Paper Trading Balance (virtual USD)
INITIAL_BALANCE=500.0

# Risk Management
MAX_RISK_PER_TRADE_PCT=2.0
MAX_CONCURRENT_POSITIONS=5
STOP_LOSS_PCT=2.0
DAILY_MAX_LOSS_PCT=5.0
WEEKLY_MAX_LOSS_PCT=10.0
DRAWDOWN_PAUSE_PCT=15.0

# Bot Scheduling
CHECK_INTERVAL_SECONDS=300
